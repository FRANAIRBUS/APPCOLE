rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function schoolUserDoc(schoolId) {
      return /databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid);
    }
    function inSchool(schoolId) { return signedIn() && exists(schoolUserDoc(schoolId)); }
    function myRole(schoolId) { return get(schoolUserDoc(schoolId)).data.role; }
    function isStaff(schoolId) { return inSchool(schoolId) && (myRole(schoolId) in ['moderator', 'admin']); }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    match /schools/{schoolId} {
      allow read: if inSchool(schoolId);
      allow write: if false;

      match /classes/{classId} {
        allow read: if inSchool(schoolId);
        allow write: if isStaff(schoolId);
      }

      match /users/{uid} {
        allow read: if inSchool(schoolId);
        allow create: if isOwner(uid);
        allow update: if isOwner(uid) || isStaff(schoolId);
        allow delete: if isOwner(uid) || isStaff(schoolId);
      }

      match /posts/{postId} {
        allow read: if inSchool(schoolId);
        allow create: if inSchool(schoolId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.status == 'active';
        allow update, delete: if inSchool(schoolId)
          && (resource.data.authorUid == request.auth.uid || isStaff(schoolId));
      }

      match /events/{eventId} {
        allow read: if inSchool(schoolId);
        allow create: if inSchool(schoolId)
          && request.resource.data.organizerUid == request.auth.uid
          && request.resource.data.status == 'active';
        allow update, delete: if inSchool(schoolId)
          && (resource.data.organizerUid == request.auth.uid || isStaff(schoolId));

        match /attendees/{uid} {
          allow read: if inSchool(schoolId);
          allow create, update, delete: if inSchool(schoolId) && isOwner(uid);
        }
      }

      match /reports/{reportId} {
        allow create: if inSchool(schoolId)
          && request.resource.data.reporterUid == request.auth.uid;
        allow read, update: if isStaff(schoolId);
        allow delete: if false;
      }

      match /connections/{connectionId} {
        allow read: if inSchool(schoolId)
          && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isStaff(schoolId));
        allow create: if inSchool(schoolId) && request.resource.data.fromUid == request.auth.uid;
        allow update: if inSchool(schoolId)
          && (resource.data.toUid == request.auth.uid || isStaff(schoolId));
        allow delete: if false;
      }

      match /inviteCodes/{code} {
        allow read, write: if false;
      }
    }
  }
}
