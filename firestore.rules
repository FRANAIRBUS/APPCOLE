rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userPath(schoolId) {
      return /databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid);
    }

    function belongsToSchool(schoolId) {
      return isSignedIn() && exists(userPath(schoolId));
    }

    function isParticipant() {
      return request.auth.uid in resource.data.participants;
    }

    match /schools/{schoolId} {
      allow read: if belongsToSchool(schoolId);
      allow write: if false;

      match /users/{uid} {
        allow read: if belongsToSchool(schoolId);
        allow create, update: if request.auth.uid == uid;
        allow delete: if request.auth.uid == uid;
      }

      match /posts/{postId} {
        allow read: if belongsToSchool(schoolId);
        allow create: if belongsToSchool(schoolId) && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if belongsToSchool(schoolId) && resource.data.authorUid == request.auth.uid;
      }

      match /events/{eventId} {
        allow read: if belongsToSchool(schoolId);
        allow create: if belongsToSchool(schoolId) && request.resource.data.organizerUid == request.auth.uid;
        allow update, delete: if belongsToSchool(schoolId) && resource.data.organizerUid == request.auth.uid;
      }

      match /chats/{chatId} {
        allow read: if belongsToSchool(schoolId) && isParticipant();
        allow create, update: if belongsToSchool(schoolId)
          && request.auth.uid in request.resource.data.participants
          && request.resource.data.participants.size() == 2;
        allow delete: if false;

        match /messages/{messageId} {
          allow read: if belongsToSchool(schoolId) && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
          allow create: if belongsToSchool(schoolId)
            && request.resource.data.senderUid == request.auth.uid
            && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
          allow update, delete: if false;
        }
      }

      match /inviteCodes/{code} {
        allow read, write: if false;
      }
    }
  }
}
