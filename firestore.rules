rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function schoolUserDoc(schoolId) {
      return /databases/$(database)/documents/schools/$(schoolId)/users/$(request.auth.uid);
    }
    function userDoc(schoolId, uid) {
      return /databases/$(database)/documents/schools/$(schoolId)/users/$(uid);
    }
    function inSchool(schoolId) { return signedIn() && exists(schoolUserDoc(schoolId)); }
    function myRole(schoolId) { return get(schoolUserDoc(schoolId)).data.role; }
    function isStaff(schoolId) { return inSchool(schoolId) && (myRole(schoolId) in ['moderator', 'admin']); }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // Seguridad: evitar escalada de privilegios vía /users/{uid}.
    // - El cliente NO puede mutar role/classIds/children ni borrar su doc.
    // - Solo permite campos de perfil y telemetría mínimos.
    function userSelfWritableKeys() {
      return [
        'displayName',
        'photoUrl',
        'professional',
        'children',
        'classIds',
        'extraGroupIds',
        'fcmTokens',
        'lastActiveAt',
        'updatedAt',
      ];
    }
    function isSafeSelfUserUpdate() {
      // Solo permitir cambiar un subconjunto pequeño de claves.
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(userSelfWritableKeys())
        // Inmutables
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt;
    }
    function isChatParticipant(schoolId, chatId) {
      return inSchool(schoolId)
        && request.auth.uid in get(/databases/$(database)/documents/schools/$(schoolId)/chats/$(chatId)).data.participants;
    }

    match /schools/{schoolId} {
      // Permite al cliente autenticado enumerar escuelas para resolver su membresía
      // (el acceso a datos sensibles sigue restringido en subcolecciones).
      allow read: if signedIn();
      allow write: if false;

      match /classes/{classId} {
        allow read: if inSchool(schoolId);
        allow write: if isStaff(schoolId);
      }

      match /users/{uid} {
        // Permite al usuario leer su propio documento aunque aún no haya "inSchool"
        // (necesario para resolver membresía desde collectionGroup durante onboarding)
        allow read: if isOwner(uid) || inSchool(schoolId);

        // Alta de membresía solo por Cloud Function (Admin SDK)
        allow create: if false;

        // El usuario solo puede actualizar campos inocuos de su perfil.
        allow update: if isOwner(uid) && isSafeSelfUserUpdate();

        // Staff puede actualizar usuarios (p.ej. role) desde UI interna o Admin SDK.
        // Nota: no permitir delete desde cliente; el borrado real va por Function.
        allow update: if isStaff(schoolId);
        allow delete: if false;
      }

      match /posts/{postId} {
        allow read: if inSchool(schoolId);
        allow create: if inSchool(schoolId)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.status == 'active'
          && request.resource.data.module is string
          && request.resource.data.title is string
          && request.resource.data.body is string;
        allow update, delete: if inSchool(schoolId)
          && (resource.data.authorUid == request.auth.uid || isStaff(schoolId));
      }

      match /events/{eventId} {
        allow read: if inSchool(schoolId);
        allow create: if inSchool(schoolId)
          && request.resource.data.organizerUid == request.auth.uid
          && request.resource.data.status == 'active'
          && request.resource.data.title is string
          && request.resource.data.place is string;
        allow update, delete: if inSchool(schoolId)
          && (resource.data.organizerUid == request.auth.uid || isStaff(schoolId));

        match /attendees/{uid} {
          allow read: if inSchool(schoolId);
          allow create, update, delete: if inSchool(schoolId) && isOwner(uid);
        }
      }

      match /reports/{reportId} {
        allow create: if inSchool(schoolId)
          && request.resource.data.reporterUid == request.auth.uid;
        allow read, update: if isStaff(schoolId);
        allow delete: if false;
      }

      match /connections/{connectionId} {
        allow read: if inSchool(schoolId)
          && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isStaff(schoolId));
        allow create: if inSchool(schoolId)
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.toUid is string
          && request.resource.data.toUid != request.auth.uid
          && request.resource.data.status == 'pending'
          && exists(userDoc(schoolId, request.resource.data.toUid));
        allow update: if inSchool(schoolId)
          && (resource.data.toUid == request.auth.uid || isStaff(schoolId));
        allow delete: if false;
      }

      match /chats/{chatId} {
        allow read: if inSchool(schoolId) && request.auth.uid in resource.data.participants;

        // Crear/enviar/actualizar chats solo por Cloud Functions (anti-spam + integridad lastMessage)
        allow create, update, delete: if false;

        match /messages/{messageId} {
          allow read: if isChatParticipant(schoolId, chatId);

          // Escritura por Function para validar y actualizar lastMessage de forma atómica.
          allow create, update, delete: if false;
        }
      }

      match /inviteCodes/{code} {
        allow read, write: if false;
      }
    }
  }
}
